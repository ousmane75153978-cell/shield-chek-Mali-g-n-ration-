class SplashCheck extends StatefulWidget {
  @override
  _SplashCheckState createState() => _SplashCheckState();
}

class _SplashCheckState extends State<SplashCheck> {
  @override
  void initState() {
    super.initState();
    checkDevice();
  }

  Future<void> checkDevice() async {
    String? imei = await storage.read(key: 'imei');
    if (imei == null) {
      Navigator.pushReplacement(context, MaterialPageRoute(builder: (_) => ActivationScreen()));
      return;
    }
    final res = await Supabase.instance.client.from('objets_voles').select('statut').eq('identifiant', imei).maybeSingle();
    if (res != null && res['statut'] == 'recherche') {
      Navigator.pushReplacement(context, MaterialPageRoute(builder: (_) => EcranVole()));
    } else {
      Navigator.pushReplacement(context, MaterialPageRoute(builder: (_) => HomeScreen()));
    }
  }

  @override
  Widget build(BuildContext context) => Scaffold(body: Center(child: CircularProgressIndicator()));
}

class EcranVole extends StatefulWidget {
  @override
  _EcranVoleState createState() => _EcranVoleState();
}

class _EcranVoleState extends State<EcranVole> {
  @override
  void initState() {
    super.initState();
    initRealtime();
  }

  void initRealtime() async {
    String? imei = await storage.read(key: 'imei');
    Supabase.instance.client.channel('public:objets_voles').on(RealtimeListenTypes.postgresChanges, 
        ChannelFilter(event: 'UPDATE', schema: 'public', table: 'objets_voles', filter: 'identifiant=eq.$imei'), 
        (payload, [ref]) {
          if (payload['new']['statut'] != 'recherche') {
            Navigator.pushReplacement(context, MaterialPageRoute(builder: (_) => HomeScreen()));
          }
        }).subscribe();
  }

  @override
  Widget build(BuildContext context) {
    return PopScope(canPop: false, child: Scaffold(backgroundColor: Colors.red[900], body: Center(child: Text("TÉLÉPHONE EN ZONE DE SÉCURITÉ", style: TextStyle(color: Colors.white, fontSize: 25)))));
  }
}

class ActivationScreen extends StatelessWidget {
  final TextEditingController imeiCtrl = TextEditingController();
  @override
  Widget build(BuildContext context) => Scaffold(body: Padding(padding: EdgeInsets.all(20), child: Column(mainAxisAlignment: MainAxisAlignment.center, children: [
    TextField(controller: imeiCtrl, keyboardType: TextInputType.number, decoration: InputDecoration(labelText: "IMEI (15 chiffres)")),
    ElevatedButton(onPressed: () async {
      if (imeiCtrl.text.length == 15) {
        await storage.write(key: 'imei', value: imeiCtrl.text.trim());
        Navigator.pushReplacement(context, MaterialPageRoute(builder: (_) => SplashCheck()));
      }
    }, child: Text("ACTIVER"))
  ])));
}

